<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Network access: HuggingFace model downloads + LLM provider APIs -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Read/write files the user picks via NSOpenPanel / NSSavePanel / drag-and-drop -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Embedded SPM binary xcframeworks (MetalWhisper/CTranslate2/OnnxRuntime) get
	     re-signed with our Developer ID at copy-on-embed time, so library validation
	     should pass. Leaving this false to keep the hardening strict. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<false/>

	<!-- Explicitly disable get-task-allow for notarization. Apple rejects notarization
	     submissions that include this entitlement (it allows debugger attachment,
	     which is fine for local dev but forbidden in distributable builds). Xcode
	     auto-injects it unless we override here. -->
	<key>com.apple.security.get-task-allow</key>
	<false/>
</dict>
</plist>
